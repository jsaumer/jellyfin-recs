# ---- Jellyfin ----
JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=your_jellyfin_api_key
# Provide ONE of these (username is auto-resolved to an ID):
JELLYFIN_USERNAME=saumz
# JELLYFIN_USER_ID=

# NOTE ON PRECEDENCE: settings marked (first-boot default) below seed the
# dashboard Settings page on first run. Once saved there, /data/settings.json
# WINS and changing the env var has no further effect. API keys and URLs are
# NEVER managed in settings — they always come from here.

# ---- Claude / Anthropic ----
ANTHROPIC_API_KEY=your_anthropic_api_key
CLAUDE_MODEL=claude-sonnet-4-6
# (first-boot default) picks per genre deep-dive section
RECS_PER_GENRE=3

# ---- TMDB (optional) ----
# Enriches recommendations with posters, ★ ratings, IMDb/TMDB links, and exact
# TMDB/TVDB IDs for precise Radarr/Sonarr staging. Leave blank to skip (no-op).
# Get a free key at https://www.themoviedb.org/settings/api
# TMDB_API_KEY=your_tmdb_api_key

# ---- Dashboard ----
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8577

# ---- Scheduler ----
# (first-boot default) the Settings page owns this afterwards; a change there
# applies to the running scheduler without a redeploy.
REFRESH_INTERVAL_HOURS=168

# ---- Radarr / Sonarr ----
# (first-boot default) staging is toggled from the Settings page afterwards.
STAGING_ENABLED=false
RADARR_URL=http://localhost:7878
RADARR_API_KEY=
# (first-boot default) quality profile NAME; "" = auto (use the profile most of
# your library already uses). Resolved by name, live, at every grab — so a
# Profilarr re-sync that renumbers IDs can't silently change your quality.
RADARR_QUALITY_PROFILE=
RADARR_ROOT_FOLDER=/movies
SONARR_URL=http://localhost:8989
SONARR_API_KEY=
SONARR_QUALITY_PROFILE=

# ---- Search on grab (first-boot defaults; Settings page owns them after) ----
# Movies: search immediately when a title is grabbed.
SEARCH_ON_GRAB_MOVIES=true
# TV & Cartoons: off | first_season | all
SEARCH_ON_GRAB_TV=off
# Sonarr holds BOTH TV and Cartoons as series but in different root folders.
# The app reads your live root folders from Sonarr and matches these hints
# (exact path first, then case-insensitive substring). Set them to whatever
# Sonarr actually reports — e.g. "/data/media/tv" and "/data/media/cartoons",
# or just distinctive substrings like "tv" and "cartoon".
SONARR_TV_ROOT_HINT=/tv
SONARR_CARTOON_ROOT_HINT=/cartoon
